{
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "dev": "pnpm run dev:api:inmemory",
    "dev:api:inmemory": "pnpm --filter @copilot/api clean && turbo run dev:inmemory --filter=@copilot/api",
    "dev:api:local": "pnpm --filter @copilot/api clean && turbo run dev:local --filter=@copilot/api",
    "dev:web": "pnpm --filter @copilot/web clean && turbo run dev --filter=@copilot/web",
    "build": "turbo run build",
    "lint:api:debug": "pnpm --filter @copilot/api exec eslint src --debug --no-cache",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "check": "turbo run lint typecheck test",
    "clean": "turbo run clean && rimraf .turbo",
    "clean:cache": "rimraf .turbo"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@next/eslint-plugin-next": "16.2.0",
    "@types/node": "25.5.0",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sonarjs": "4.0.2",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  }
}
