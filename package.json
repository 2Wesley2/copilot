{
  "name": "copilot",
  "private": true,
  "packageManager": "pnpm@10.31.0",
  "scripts": {
    "build": "turbo run build",
    "build:shared": "pnpm --filter @copilot/shared build",
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @copilot/shared build && pnpm -r --parallel --filter @copilot/shared --filter @copilot/api run dev",
    "start:api": "pnpm --filter @copilot/shared build && pnpm --filter @copilot/api start",
    "start:api:test": "pnpm --filter @copilot/shared build && pnpm --filter @copilot/api start:test",
    "start:api:prod": "pnpm --filter @copilot/shared build && pnpm --filter @copilot/api start:prod",
    "typecheck": "turbo run typecheck",
    "lint": "pnpm exec eslint . --max-warnings=0",
    "lint:fix": "pnpm exec eslint . --fix",
    "lint:api": "pnpm --filter @copilot/api lint",
    "lint:web": "pnpm --filter @copilot/web lint",
    "format": "pnpm exec prettier . --check",
    "format:write": "pnpm exec prettier . --write",
    "test": "turbo run test",
    "db:seed": "pnpm --filter @copilot/api db:seed"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@next/eslint-plugin-next": "16.1.6",
    "@types/node": "25.3.5",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-boundaries": "5.4.0",
    "eslint-plugin-import-x": "4.16.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-simple-import-sort": "12.1.1",
    "eslint-plugin-sonarjs": "4.0.1",
    "eslint-plugin-unicorn": "63.0.0",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "prettier": "3.8.1",
    "turbo": "2.8.14",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
