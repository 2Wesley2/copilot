{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],

    "rootDir": "./src",
    "outDir": "./dist",

    "tsBuildInfoFile": "./node_modules/.cache/tsconfig.shared.tsbuildinfo",

    "composite": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "inlineSources": false
  },
  "include": ["src/**/*.ts"],
  "exclude": ["dist", "node_modules"]
}
