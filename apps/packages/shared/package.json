{
  "name": "@copilot/shared",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils/is-nullish": {
      "types": "./dist/utils/is-nullish.d.ts",
      "import": "./dist/utils/is-nullish.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm exec eslint src"
  }
}
