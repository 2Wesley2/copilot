{
  "name": "@copilot/shared",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "files": ["dist", "src"],
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./dist/utils/index.js",
      "default": "./dist/utils/index.js"
    },
    "./utils/is-nullish": {
      "types": "./src/utils/is-nullish.ts",
      "import": "./dist/utils/is-nullish.js",
      "default": "./dist/utils/is-nullish.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -w -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "pnpm exec eslint src",
    "clean": "rimraf dist node_modules/.cache/tsconfig.shared.tsbuildinfo"
  },
  "devDependencies": {
    "rimraf": "^6.1.3"
  }
}
